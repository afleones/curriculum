<script>
	type Lang = "es" | "en";

	const root = document.querySelector<HTMLElement>(".cv-shell");
	const toggle = document.querySelector<HTMLButtonElement>("#langToggle");
	const menuToggle = document.querySelector<HTMLButtonElement>("#menuToggle");
	const topbar = document.querySelector<HTMLElement>(".topbar");

	const applyLanguage = (lang: Lang) => {
		if (!root || !toggle) return;
		const toggleLabel = toggle.querySelector<HTMLSpanElement>("span");

		root.setAttribute("data-lang", lang);
		toggleLabel?.setAttribute("data-active", lang);

		document.querySelectorAll("[data-es][data-en]").forEach((node) => {
			node.textContent =
				node.getAttribute(lang === "es" ? "data-es" : "data-en") ?? "";
		});

		if (toggleLabel) {
			toggleLabel.textContent = lang.toUpperCase();
		}
		localStorage.setItem("cv-lang", lang);
	};

	const saved = localStorage.getItem("cv-lang");
	applyLanguage(saved === "en" ? "en" : "es");

	toggle?.addEventListener("click", () => {
		const nextLang = root?.getAttribute("data-lang") === "es" ? "en" : "es";
		applyLanguage(nextLang);
	});

	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add("is-visible");
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.15 },
	);

	document
		.querySelectorAll(".reveal")
		.forEach((section) => observer.observe(section));

	const typedName = document.querySelector<HTMLElement>("#typedName");
	const fullName = typedName?.dataset.fullname ?? "";

	const runTypingName = () => {
		if (!typedName) return;
		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			typedName.textContent = fullName;
			typedName.classList.remove("is-typing");
			return;
		}

		typedName.textContent = "";

		let i = 0;
		let deleting = false;
		const TYPE_DELAY_MS = 58;
		const DELETE_DELAY_MS = 42;
		const HOLD_FULL_MS = 3000;
		const HOLD_EMPTY_MS = 350;

		const loop = () => {
			typedName.classList.add("is-typing");

			if (!deleting) {
				i += 1;
				typedName.textContent = fullName.slice(0, i);

				if (i >= fullName.length) {
					deleting = true;
					typedName.classList.remove("is-typing");
					window.setTimeout(loop, HOLD_FULL_MS);
					return;
				}

				window.setTimeout(loop, TYPE_DELAY_MS);
				return;
			}

			i -= 1;
			typedName.textContent = fullName.slice(0, Math.max(i, 0));

			if (i <= 0) {
				deleting = false;
				typedName.classList.remove("is-typing");
				window.setTimeout(loop, HOLD_EMPTY_MS);
				return;
			}

			window.setTimeout(loop, DELETE_DELAY_MS);
		};

		window.setTimeout(loop, 250);
	};

	runTypingName();

	const parallaxSections = document.querySelectorAll<HTMLElement>(
		".parallax-section[data-parallax]",
	);

	let parallaxTicking = false;

	const updateParallax = () => {
		const viewportCenter = window.scrollY + window.innerHeight * 0.5;
		parallaxSections.forEach((section) => {
			const speedRaw = Number.parseFloat(
				section.dataset.parallax ?? "0.025",
			);
			const speed = Number.isFinite(speedRaw) ? speedRaw : 0.025;
			const sectionCenter =
				section.offsetTop + section.offsetHeight * 0.5;
			const distance = viewportCenter - sectionCenter;
			const offset = Math.max(Math.min(distance * speed, 26), -26);
			section.style.setProperty(
				"--parallax-offset",
				`${offset.toFixed(2)}px`,
			);
		});
		parallaxTicking = false;
	};

	const scheduleParallax = () => {
		if (parallaxTicking) return;
		parallaxTicking = true;
		window.requestAnimationFrame(updateParallax);
	};

	window.addEventListener("scroll", scheduleParallax, { passive: true });
	window.addEventListener("resize", scheduleParallax);
	updateParallax();

	const navLinks = Array.from(
		document.querySelectorAll<HTMLAnchorElement>(".top-nav .nav-link"),
	);

	const sectionIds = navLinks
		.map((link) => link.getAttribute("href")?.replace("#", "") ?? "")
		.filter((id) => id.length > 0);

	const contactSectionId = "contacto";
	const trackedSectionIds = sectionIds.filter(
		(id) => id !== contactSectionId,
	);

	const trackedSections = trackedSectionIds
		.map((id) => document.getElementById(id))
		.filter((node): node is HTMLElement => node instanceof HTMLElement);

	const contactSection = document.getElementById(contactSectionId);

	const setActiveNav = (activeId: string) => {
		navLinks.forEach((link) => {
			const isActive = link.getAttribute("href") === `#${activeId}`;
			link.classList.toggle("is-active", isActive);
		});
	};

	const updateActiveSection = () => {
		if (trackedSections.length === 0) return;
		const topbarOffset = (topbar?.offsetHeight ?? 84) + 28;
		const markerY = topbarOffset + 10;
		const nearBottom =
			window.scrollY + window.innerHeight >=
			document.documentElement.scrollHeight - 120;

		if (nearBottom && sectionIds.includes(contactSectionId)) {
			setActiveNav(contactSectionId);
			return;
		}

		if (
			contactSection instanceof HTMLElement &&
			window.location.hash === `#${contactSectionId}`
		) {
			const contactRect = contactSection.getBoundingClientRect();
			if (contactRect.top <= markerY && contactRect.bottom >= markerY) {
				setActiveNav(contactSectionId);
				return;
			}
		}

		let current = trackedSections[0];

		trackedSections.forEach((section) => {
			const sectionTop = section.getBoundingClientRect().top;
			if (sectionTop <= markerY) {
				current = section;
			}
		});

		if (window.scrollY < 60 && sectionIds.includes("inicio")) {
			setActiveNav("inicio");
			return;
		}

		setActiveNav(current.id);
	};

	const closeMobileMenu = () => {
		if (!topbar || !menuToggle) return;
		topbar.classList.remove("is-menu-open");
		menuToggle.setAttribute("aria-expanded", "false");
	};

	menuToggle?.addEventListener("click", () => {
		if (!topbar || !menuToggle) return;
		const opened = topbar.classList.toggle("is-menu-open");
		menuToggle.setAttribute("aria-expanded", String(opened));
	});

	navLinks.forEach((link) => {
		link.addEventListener("click", () => {
			if (window.innerWidth <= 640) {
				closeMobileMenu();
			}
		});
	});

	document.addEventListener("click", (event) => {
		if (!topbar || !menuToggle) return;
		if (window.innerWidth > 640) return;
		if (!topbar.classList.contains("is-menu-open")) return;
		const target = event.target;
		if (!(target instanceof Node)) return;
		if (!topbar.contains(target)) {
			closeMobileMenu();
		}
	});

	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") {
			closeMobileMenu();
		}
	});

	window.addEventListener("scroll", updateActiveSection, { passive: true });
	window.addEventListener("resize", () => {
		if (window.innerWidth > 640) {
			closeMobileMenu();
		}
		updateActiveSection();
	});
	window.addEventListener("hashchange", updateActiveSection);
	updateActiveSection();

	document
		.querySelectorAll<HTMLElement>(".skill-group-card")
		.forEach((card) => {
			const toggleBtn = card.querySelector<HTMLButtonElement>(
				".skill-group-toggle",
			);
			if (!toggleBtn) return;

			toggleBtn.addEventListener("click", () => {
				const expanded = card.classList.toggle("is-open");
				toggleBtn.setAttribute("aria-expanded", String(expanded));
			});
		});
</script>

