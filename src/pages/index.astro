<Layout
	title="Andrés Leones | CV Bilingue"
	description="CV bilingue en espanol e ingles con animaciones y diseno responsive."
>
	<div class="noise"></div>
	<div class="bg-orb orb-a"></div>
	<div class="bg-orb orb-b"></div>

	<main class="cv-shell" data-lang="es">
		<header class="topbar reveal">
			<div class="brand">
				<span class="dot"></span>
				<p class="brand-dev">&lt;HelloWorld /&gt;</p>
			</div>
			<div class="controls">
				<button
					id="langToggle"
					class="lang-btn"
					type="button"
					aria-label="Toggle language"
				>
					<span data-es="ES" data-en="EN">ES</span>
				</button>
				<button
					id="menuToggle"
					class="menu-toggle"
					type="button"
					aria-label="Abrir menu"
					aria-controls="mainNav"
					aria-expanded="false"
				>
					<span class="menu-bar" aria-hidden="true"></span>
					<span class="menu-bar" aria-hidden="true"></span>
					<span class="menu-bar" aria-hidden="true"></span>
				</button>
				<nav
					class="top-nav"
					id="mainNav"
					aria-label="Navegacion principal"
				>
					<a class="nav-link" href="#inicio">Inicio</a>
					<a class="nav-link" href="#logros">Logros</a>
					<a class="nav-link" href="#habilidades">Habilidades</a>
					<a class="nav-link" href="#experiencia">Experiencia</a>
					<a class="nav-link" href="#proyectos">Proyectos</a>
					<a class="nav-link" href="#educacion">Educacion</a>
				</nav>
			</div>
		</header>

		<section
			class="hero reveal parallax-section"
			id="inicio"
			data-parallax="0.045"
		>
			<div class="hero-copy">
				<p
					class="eyebrow"
					data-es="Disponible para oportunidades remotas y locales"
					data-en="Open to remote and local opportunities"
				>
					Disponible para oportunidades remotas y locales
				</p>
				<h1>
					<span
						id="typedName"
						class="typing-name"
